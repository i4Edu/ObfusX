#!/usr/bin/env php
<?php

declare(strict_types=1);

require_once __DIR__ . '/../src/bootstrap.php';
require_once __DIR__ . '/../runtime/loader.php';

use ObfusX\Encoder;
use ObfusX\LicenseManager;
use ObfusX\Version;

function parseArgs(array $argv): array
{
    $args = [];
    foreach ($argv as $arg) {
        if (str_starts_with($arg, '--')) {
            $parts = explode('=', substr($arg, 2), 2);
            $args[$parts[0]] = $parts[1] ?? '1';
        }
    }
    return $args;
}

function usage(): void
{
    echo 'ObfusX CLI v' . Version::current() . "\n";
    echo "  encode --in=/path/input.php --out=/path/output.obx\n";
    echo "  run --file=/path/output.obx [--license=/path/license.json]\n";
    echo "  inspect --file=/path/output.obx\n";
    echo "  make-license --out=/path/license.json [--domain=example.com] [--ip=1.2.3.4] [--expires=2030-01-01T00:00:00Z] [--hw=<fingerprint>]\n";
    echo "  fingerprint\n";
    echo "  about\n";
    echo "  version\n";
    echo "  help\n";
}

function about(): void
{
    $v = Version::current();
    echo "╔══════════════════════════════════════════════════════╗\n";
    echo "║         ObfusX v{$v} — PHP Source Protection" . str_repeat(' ', 12 - strlen($v)) . "║\n";
    echo "║       Inspired by ionCube/SourceGuardian workflows   ║\n";
    echo "╠══════════════════════════════════════════════════════╣\n";
    echo "║  PHP req.  : 8.1+                                    ║\n";
    echo "║  License   : MIT                                     ║\n";
    echo "║  Project   : https://github.com/i4Edu/ObfusX        ║\n";
    echo "╠══════════════════════════════════════════════════════╣\n";
    echo "║  Features                                            ║\n";
    echo "║  • AES-256-GCM encryption of PHP source payloads    ║\n";
    echo "║  • Identifier & string-literal obfuscation pipeline ║\n";
    echo "║  • In-memory decrypt-and-eval runtime loader        ║\n";
    echo "║  • Domain / IP / hardware-fingerprint license checks║\n";
    echo "║  • Configurable expiry date enforcement             ║\n";
    echo "║  • Anti-debug checks (xdebug, phpdbg, trace …)     ║\n";
    echo "║  • Laravel-compatible __DIR__ / __FILE__ rewriting  ║\n";
    echo "║  • HKDF key derivation with rotation support        ║\n";
    echo "║  • Optional gzip compression before encryption      ║\n";
    echo "║  • Optional HMAC payload tamper detection           ║\n";
    echo "╠══════════════════════════════════════════════════════╣\n";
    echo "║  Commands                                            ║\n";
    echo "║  encode · run · inspect · make-license              ║\n";
    echo "║  fingerprint · version · about · help               ║\n";
    echo "╚══════════════════════════════════════════════════════╝\n";
}

$command = $argv[1] ?? null;
$args = parseArgs(array_slice($argv, 2));

if (isset($args['help'])) {
    usage();
    exit(0);
}

try {
    switch ($command) {
        case 'encode':
            $in = $args['in'] ?? null;
            $out = $args['out'] ?? null;
            $key = getenv('OBFUSX_MASTER_KEY') ?: '';
            if (!$in || !$out || $key === '') {
                throw new RuntimeException('encode requires --in, --out and OBFUSX_MASTER_KEY.');
            }
            Encoder::encodeFile($in, $out, $key);
            echo "Encoded: {$out}\n";
            break;

        case 'run':
            $file = $args['file'] ?? null;
            if (!$file) {
                throw new RuntimeException('run requires --file.');
            }
            obfusx_execute_file($file, $args['license'] ?? null);
            break;

        case 'make-license':
            $out = $args['out'] ?? null;
            $signingKey = getenv('OBFUSX_LICENSE_KEY') ?: '';
            if (!$out || $signingKey === '') {
                throw new RuntimeException('make-license requires --out and OBFUSX_LICENSE_KEY.');
            }

            $license = LicenseManager::create(
                [
                    'domain' => $args['domain'] ?? null,
                    'ip' => $args['ip'] ?? null,
                    'expires_at' => $args['expires'] ?? null,
                    'hardware_fingerprint' => $args['hw'] ?? null,
                ],
                $signingKey
            );

            if (file_put_contents($out, $license) === false) {
                throw new RuntimeException('Unable to write license file.');
            }

            echo "License created: {$out}\n";
            break;

        case 'fingerprint':
            echo LicenseManager::hardwareFingerprint() . PHP_EOL;
            break;

        case 'inspect':
            $file = $args['file'] ?? null;
            if (!$file) {
                throw new RuntimeException('inspect requires --file.');
            }
            $info = Encoder::describeFile($file);
            echo json_encode($info, JSON_PRETTY_PRINT | JSON_UNESCAPED_SLASHES) . PHP_EOL;
            break;

        case 'version':
            echo Version::current() . PHP_EOL;
            break;

        case 'about':
            about();
            break;

        case 'help':
            usage();
            break;

        default:
            usage();
            exit($command === null ? 0 : 1);
    }
} catch (Throwable $e) {
    fwrite(STDERR, 'Error: ' . $e->getMessage() . PHP_EOL);
    exit(1);
}
