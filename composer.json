{
    "name": "i4edu/obfusx",
    "description": "PHP source-protection toolkit with encryption, obfuscation, runtime loading, and license checks.",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": "^8.1",
        "ext-json": "*",
        "ext-openssl": "*"
    },
    "require-dev": {
        "phpstan/phpstan": "2.2.2"
    },
    "autoload": {
        "psr-4": {
            "ObfusX\\": "src/"
        }
    },
    "bin": [
        "bin/obfusx"
    ],
    "scripts": {
        "test": "php ./tests/run.php",
        "stan": "phpstan analyse --configuration=phpstan.neon.dist"
    },
    "config": {
        "sort-packages": true
    }
}
